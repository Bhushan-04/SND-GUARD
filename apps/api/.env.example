# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Prisma → Supabase Postgres (no quotes on Render)
DATABASE_URL=postgresql://postgres.your-project:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

PORT=3000
COUNTERFACTUAL_RELATED_LIMIT=10
COUNTERFACTUAL_POISON_THRESHOLD=30
COUNTERFACTUAL_AUTO_REVOKE_THRESHOLD=80
MIN_CONSUMABLE_TRUST_SCORE=50

# local = stubs; production = real Walrus + Sui testnet
ADAPTER_MODE=production

# Sui testnet — use original package id after upgrade
SUI_NETWORK=testnet
SUI_PACKAGE_ID=0x9c5dd6abaacf9a6a3ba6fa50daf39a0a378458fdc22df69fa2732c93fda04bea

# On-chain txs: set ONE of these (see docs/DEPLOY.md)
# sui keytool export --key-identity <your-address>
SUI_SECRET_KEY=
# SUI_MNEMONIC=

# Walrus testnet (no wallet / API key)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# Optional LLM counterfactual enrichment
LLM_PROVIDER=none
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

CORS_ORIGIN=http://localhost:3001
