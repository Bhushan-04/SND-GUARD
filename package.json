{
  "name": "snd-guard",
  "version": "0.1.0",
  "private": true,
  "description": "SNDGuard — AI Memory Security Middleware",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev --prefix apps/api",
    "dev:web": "npm run dev --prefix apps/web",
    "build": "npm run build -w @snd-guard/shared && npm run build -w @snd-guard/api && npm run build -w @snd-guard/web",
    "build:api": "npm run build -w @snd-guard/api",
    "build:web": "npm run build -w @snd-guard/web",
    "start:api": "npm run start -w @snd-guard/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "license": "MIT"
}
